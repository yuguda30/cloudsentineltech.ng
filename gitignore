!.vscode/extensions.json

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*.swn
Session.vim
.netrwhist

# Emacs
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc


# ── Logs & Debugging ─────────────────────────────────────────
logs/
*.log
npm-debug.log
server.log
error.log
access.log


# ── Backup & Temporary Files ─────────────────────────────────
*.bak
*.backup
*.orig
*.tmp
*.temp
*.old
~$*
.sass-cache/
*.css.map
*.js.map


# ── Security-Sensitive Files ─────────────────────────────────
