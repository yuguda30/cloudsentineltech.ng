*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.csr

# SSH keys
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
known_hosts


# ── Deployment & Hosting Config ──────────────────────────────
