.ftppass
deploy.config.js
deploy-config.json
sftp.json
.netlify/
vercel.json
# Note: keep CNAME if using GitHub Pages custom domain
# CNAME is intentionally NOT ignored


# ── Future Backend / API (when added) ────────────────────────
server/private/
api/keys/
api/config/
*.secret.js


